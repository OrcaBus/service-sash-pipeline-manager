<mxfile host="app.diagrams.net">
  <diagram name="glue-succeeded-events-to-draft-update" id="glue-succeeded-events-to-draft-update">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════ COLUMN A — NODES ═══════════════ -->

        <!-- Start oval -->
        <mxCell id="n1" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="147" y="30" width="56" height="36" as="geometry"/>
        </mxCell>

        <!-- Step: Get upstream workflow run object -->
        <mxCell id="n2" value="Get upstream workflow run object" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="110" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Find matching DRAFT workflow runs -->
        <mxCell id="n3" value="Find matching DRAFT workflow runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="220" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: DRAFT found? -->
        <mxCell id="n4" value="DRAFT found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="330" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: For each matching DRAFT (Map) -->
        <mxCell id="n5" value="For each matching DRAFT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="440" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success (no DRAFT found — side float) -->
        <mxCell id="n6" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="400" y="338" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ COLUMN B — NODES ═══════════════ -->

        <!-- Step: Get current DRAFT payload -->
        <mxCell id="n7" value="Get current DRAFT payload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="110" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Retrieve upstream workflow outputs -->
        <mxCell id="n8" value="Retrieve upstream workflow outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="220" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Merge upstream outputs into DRAFT payload -->
        <mxCell id="n9" value="Merge upstream outputs into DRAFT payload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="330" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: Payload changed? -->
        <mxCell id="n10" value="Payload changed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="605" y="440" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Put DRAFT update event -->
        <mxCell id="n11" value="Put DRAFT update event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="550" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success (main flow — Column B) -->
        <mxCell id="n12" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="625" y="660" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success (no change — side float) -->
        <mxCell id="n13" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="925" y="448" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ EDGES ═══════════════ -->

        <!-- Start → Get upstream workflow run object -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Get upstream workflow run object → Find matching DRAFT workflow runs -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Find matching DRAFT workflow runs → DRAFT found? -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n3" target="n4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DRAFT found? → For each matching DRAFT (Yes) -->
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n4" target="n5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DRAFT found? → Success side float (No, dashed) -->
        <mxCell id="e5" value="No" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n4" target="n6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- For each matching DRAFT → Get current DRAFT payload (handoff to Column B) -->
        <mxCell id="e6" value="For each draft&#xa;portal run id" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n5" target="n7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="471"/>
              <mxPoint x="500" y="141"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Get current DRAFT payload → Retrieve upstream workflow outputs -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n7" target="n8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Retrieve upstream workflow outputs → Merge upstream outputs into DRAFT payload -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n8" target="n9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Merge upstream outputs into DRAFT payload → Payload changed? -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n9" target="n10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payload changed? → Put DRAFT update event (Yes) -->
        <mxCell id="e10" value="Yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n10" target="n11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payload changed? → Success side float (No, dashed) -->
        <mxCell id="e11" value="No" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n10" target="n13" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Put DRAFT update event → Success -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n11" target="n12" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
