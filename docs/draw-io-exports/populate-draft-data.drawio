<mxfile host="app.diagrams.net">
  <diagram name="populate-draft-data" id="populate-draft-data">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════ COLUMN A (x=25) ═══════════════ -->

        <!-- Start oval -->
        <mxCell id="n1" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="147" y="30" width="56" height="36" as="geometry"/>
        </mxCell>

        <!-- Step: Validate draft data -->
        <mxCell id="n2" value="Validate draft data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="110" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Side-float: Success (draft already valid) -->
        <mxCell id="n3" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="420" y="118" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Step: Resolve engine parameters -->
        <mxCell id="n4" value="&lt;b&gt;Resolve engine parameters&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;projectId · pipelineId · outputUri · logsUri · cacheUri&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="220" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Resolve library tags -->
        <mxCell id="n5" value="&lt;b&gt;Resolve library tags&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;fastqRgidList · tumorFastqRgidList · metadata&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="330" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: Tags or engine params changed? -->
        <mxCell id="n6" value="Tags or engine&#xa;params changed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Side-float: Put DRAFT update (intermediate) -->
        <mxCell id="n7" value="&lt;b&gt;Put DRAFT update event&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;tags / params updated&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="400" y="440" width="220" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Resolve readsets -->
        <mxCell id="n8" value="&lt;b&gt;Resolve readsets&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;normal + tumor library readsets&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="550" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ COLUMN B (x=575) ═══════════════ -->

        <!-- Step: Resolve inputs -->
        <mxCell id="n9" value="&lt;b&gt;Resolve inputs&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;dragen germline/somatic · oncoanalyser dir&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="110" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Add reference data -->
        <mxCell id="n10" value="&lt;b&gt;Add reference data&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;sash refDataPath&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="220" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Compare payload -->
        <mxCell id="n11" value="&lt;b&gt;Compare payload&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;generate WRU object + diff old vs new&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="330" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: Has changed? -->
        <mxCell id="n12" value="Payload changed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="605" y="440" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Put DRAFT update event (full) -->
        <mxCell id="n13" value="&lt;b&gt;Put DRAFT update event&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;fully populated payload&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="575" y="550" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success (main flow) -->
        <mxCell id="n14" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="625" y="660" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Side-float: No change (log missing fields) -->
        <mxCell id="n15" value="&lt;b&gt;Log missing fields&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;no-change comment&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="920" y="448" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ EDGES ═══════════════ -->

        <!-- Start → Validate draft data -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Validate draft data → Success (already valid, dashed side-float) -->
        <mxCell id="e2" value="Already valid" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Validate draft data → Resolve engine parameters -->
        <mxCell id="e3" value="Not yet valid" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n2" target="n4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Resolve engine parameters → Resolve library tags -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n4" target="n5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Resolve library tags → Tags or engine params changed? -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n5" target="n6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tags changed → Put DRAFT update (intermediate, side-float) -->
        <mxCell id="e6" value="Changed" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n6" target="n7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tags not changed → Resolve readsets (dashed bypass) -->
        <mxCell id="e7" value="No change" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n6" target="n8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Resolve readsets → Resolve inputs (cross-column handoff) -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n8" target="n9" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="175" y="640"/>
              <mxPoint x="553" y="640"/>
              <mxPoint x="553" y="141"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Resolve inputs → Add reference data -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n9" target="n10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Add reference data → Compare payload -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n10" target="n11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Compare payload → Payload changed? -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n11" target="n12" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payload changed? → Put DRAFT update event (full) (Yes) -->
        <mxCell id="e12" value="Yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n12" target="n13" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payload changed? → Log missing fields (no change, dashed side-float) -->
        <mxCell id="e13" value="No change" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n12" target="n15" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Put DRAFT update event (full) → Success -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n13" target="n14" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
